# Dev Infrastructure Environment Configuration
# Copy to .env and customize for your setup

# ============================================
# General Settings
# ============================================
COMPOSE_PROJECT_NAME=dev-infra
RBAC_USER=dev-infra-admin

# ============================================
# Vault Configuration
# ============================================
VAULT_PORT=8201
VAULT_ADDR=http://localhost:8201
VAULT_TOKEN=dev-root-token
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token

# ============================================
# Docker Registry Configuration (k3d managed)
# ============================================
REGISTRY_PORT=5002
REGISTRY_URL=http://localhost:5002
# Internal registry hostname as seen FROM inside Kubernetes nodes
# (k3d creates this automatically — no manual containerd config needed)
REGISTRY_CLUSTER_HOST=k3d-dev-infra-registry

# ============================================
# Gravitee Configuration
# ============================================
GRAVITEE_MONGO_PORT=27017
GRAVITEE_ES_PORT=9200
GRAVITEE_GATEWAY_PORT=8082
GRAVITEE_MGMT_API_PORT=8083
GRAVITEE_MGMT_UI_PORT=8084
GRAVITEE_PORTAL_UI_PORT=8085
GRAVITEE_MGMT_API_URL=http://localhost:8083
GRAVITEE_GATEWAY_URL=http://localhost:8082
GRAVITEE_ADMIN_USER=admin
GRAVITEE_ADMIN_PASS=dev-admin-pass

# ============================================
# Tekton CI/CD Configuration
# ============================================
CLUSTER_NAME=dev-infra
NAMESPACE=dev-infrastructure
TEKTON_NAMESPACE=tekton-pipelines
PIPELINE_NAMESPACE=tekton-pipelines
PIPELINE_SERVICE_ACCOUNT=tekton-sa

# Lightweight mode: installs only Pipelines controller + webhook (2 pods)
# Set to true to skip Dashboard and Triggers regardless of the flags below
TEKTON_LIGHTWEIGHT=false

# Individual component toggles (ignored when TEKTON_LIGHTWEIGHT=true)
TEKTON_INSTALL_DASHBOARD=true
TEKTON_INSTALL_TRIGGERS=true

# Dashboard access via kubectl proxy (more stable than port-forward)
TEKTON_DASHBOARD_PORT=9097
TEKTON_PROXY_PORT=8001

# Maximum time (seconds) to wait for each component to become ready
TEKTON_READY_TIMEOUT=180

# Release manifest URLs (override to pin a specific version or use a mirror)
TEKTON_PIPELINE_RELEASE_URL=https://storage.googleapis.com/tekton-releases/pipeline/latest/release.yaml
TEKTON_DASHBOARD_RELEASE_URL=https://storage.googleapis.com/tekton-releases/dashboard/latest/release.yaml
TEKTON_TRIGGERS_RELEASE_URL=https://storage.googleapis.com/tekton-releases/triggers/latest/release.yaml

REGISTRY_USERNAME=
REGISTRY_PASSWORD=
GIT_REVISION=main
GITHUB_USERNAME=
GITHUB_TOKEN=
# Secret token configured in GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
